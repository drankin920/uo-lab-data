# UO Lab Pulse — Local Server Configuration
# Copy this to .env and fill in the values.

# ─── Server ───────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0

# ─── Database ─────────────────────────────────────────────────────
# Path to the SQLite database file (default: ./data/readings.db)
# DB_PATH=/home/pi/uo-lab-pulse/server/data/readings.db

# ─── Firebase (for forwarding to Firestore) ──────────────────────
# Option 1: Path to the service account JSON file
# Download from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
GOOGLE_APPLICATION_CREDENTIALS=/path/to/uo-lab-pulse-service-account.json

# Option 2: Inline JSON (useful for Docker/CI)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"uo-lab-pulse",...}

# ─── CORS ─────────────────────────────────────────────────────────
# Additional allowed origin (e.g., your Cloudflare Tunnel domain)
# CORS_ORIGIN=https://api-uo-lab-pulse.yourdomain.com
