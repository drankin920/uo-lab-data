{
  "name": "uo-lab-pulse-server",
  "version": "1.0.0",
  "description": "Local Raspberry Pi server for UO Lab Pulse — stores sensor data in SQLite and forwards to Firestore",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "firebase-admin": "^13.0.0",
    "papaparse": "^5.4.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/papaparse": "^5.3.15",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3"
  }
}
